# ── Facecook UI — Environment Configuration ───────────────────────────────────
#
# Copy this file to .env and adjust values for your environment.
# NEVER commit .env to version control.
#
# VITE_ prefixed vars are bundled into the client at build time.
# Non-prefixed vars (e.g. ALLOWED_HOSTS) are server-side only (vite.config.ts).
# ──────────────────────────────────────────────────────────────────────────────

# ── API & WebSocket targets (used by Vite dev server proxy) ──────────────────
VITE_API_BASE=http://localhost:8080
VITE_WS_BASE=ws://localhost:8084

# ── Allowed dev-server hosts ──────────────────────────────────────────────────
# Comma-separated. A leading dot matches all subdomains, e.g. .kiet-test.work
# matches facecook.kiet-test.work, api.kiet-test.work, etc.
# Leave empty to allow localhost only.
ALLOWED_HOSTS=.kiet-test.work
