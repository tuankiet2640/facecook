# ── Facecook — Environment Configuration ──────────────────────────────────────
#
# Copy this file to .env and fill in values for local development.
# NEVER commit .env to version control.
#
# Config is loaded via the `config` crate using __ as the section separator.
# e.g. DATABASE__URL maps to AppConfig.database.url
# ──────────────────────────────────────────────────────────────────────────────

# ── Service Identity ──────────────────────────────────────────────────────────
SERVICE_NAME=gateway                          # Overridden per-service in docker-compose
ENVIRONMENT=development                       # development | staging | production

# ── Server ────────────────────────────────────────────────────────────────────
SERVER__HOST=0.0.0.0
SERVER__PORT=8080
SERVER__REQUEST_TIMEOUT_SECS=30
SERVER__MAX_REQUEST_BODY_BYTES=10485760       # 10MB

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE__URL=postgresql://facecook:facecook@localhost:5432/facecook
DATABASE__MAX_CONNECTIONS=20
DATABASE__MIN_CONNECTIONS=2
DATABASE__CONNECT_TIMEOUT_SECS=10
DATABASE__ACQUIRE_TIMEOUT_SECS=5

# ── Cache (Redis) ─────────────────────────────────────────────────────────────
REDIS__URL=redis://localhost:6379
REDIS__POOL_SIZE=10
REDIS__FEED_TTL_SECS=86400                   # 24 hours
REDIS__PRESENCE_TTL_SECS=60                  # Must heartbeat within 60s to stay online
REDIS__SESSION_TTL_SECS=3600                 # 1 hour

# ── Message Queue (Kafka) ─────────────────────────────────────────────────────
KAFKA__BROKERS=localhost:29092
KAFKA__CONSUMER_GROUP_ID=facecook-local
KAFKA__POST_EVENTS_TOPIC=post.events
KAFKA__FEED_FANOUT_TOPIC=feed.fanout
KAFKA__CHAT_MESSAGES_TOPIC=chat.messages
KAFKA__NOTIFICATION_TOPIC=notifications
KAFKA__MESSAGE_TIMEOUT_MS=5000

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH__JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
AUTH__JWT_EXPIRY_SECS=3600                   # 1 hour access token
AUTH__JWT_REFRESH_EXPIRY_SECS=604800         # 7 day refresh token

# ── Feed ──────────────────────────────────────────────────────────────────────
FEED__CELEBRITY_THRESHOLD=10000              # Users with >10K followers use fanout-on-read
FEED__MAX_FEED_SIZE=1000                     # Max posts stored in a user's Redis sorted set
FEED__FEED_PAGE_SIZE=20
FEED__POST_CACHE_TTL_SECS=3600

# ── Tracing ───────────────────────────────────────────────────────────────────
RUST_LOG=info,sqlx=warn,tower_http=debug
